# ============================================================
# ALARMA COMUNITARIA — Variables de Entorno
# ============================================================
# Copia este archivo a .env y completa los valores

# === REQUERIDO ===
# Clave secreta para firmar JWT tokens (genera una larga y aleatoria)
JWT_SECRET=genera_una_clave_larga_y_aleatoria_aqui_mas_de_32_caracteres

# === MERCADO PAGO ===
# Para pruebas: token que empieza con TEST-
# Para producción: token que empieza con APP_USR-
MP_ACCESS_TOKEN=APP_USR-tu-token-real-de-mercadopago

# === URLs ===
# URL pública del frontend (sin slash al final)
FRONTEND_URL=https://tu-dominio.com
# URL pública para links en WhatsApp (puede ser igual a FRONTEND_URL)
PUBLIC_URL=https://tu-dominio.com

# === FIREBASE (Opcional — para Push Notifications) ===
# Pega aquí TODO el contenido de firebase-service-account.json como una sola línea
# Ejemplo: FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
# Si no se configura, el servidor buscará el archivo firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT=

# === PRODUCCIÓN ===
NODE_ENV=production
PORT=3001

# === BASE DE DATOS ===
# Ruta al archivo SQLite (por defecto ./alarmas.db)
# En Docker usa /data/alarmas.db para persistencia
DB_PATH=./alarmas.db
